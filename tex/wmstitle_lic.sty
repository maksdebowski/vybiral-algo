\ProvidesPackage{wmstitle_lic}[2024/06/09 Strona tytulowa WMS AGH]

\RequirePackage{graphicx}

%------------------- Definiowanie zmiennych -------------------%
\def\engtitle#1{\gdef\@engtitle{#1}}
\def\@engtitle{\ClassError{wms_lic}{Brak tytulu angielskiego! Uzyj \string\engtitle}{}}

\def\kierunek#1{\gdef\@kierunek{#1}}
\def\@kierunek{\ClassError{wms_lic}{Brak kierunku studiow! Uzyj \string\kierunek}{}}

\def\opiekun#1{\gdef\@opiekun{#1}}
\def\@opiekun{\ClassError{wms_lic}{Brak opiekuna! Uzyj \string\opiekun}{}}

\def\nralbumu#1{\gdef\@nralbumu{#1}}
\def\@nralbumu{\ClassError{wms_lic}{Brak numeru albumu! Uzyj \string\nralbumu}{}}

%------------------- Generowanie strony tytułowej -------------------%
\renewcommand{\maketitle}{%
\begin{titlepage}
\thispagestyle{empty}

\begin{center}
% Zmieniono szerokość na stałą wysokość, aby logo nie zajmowało całej strony
\includegraphics[height=4cm]{logoAGH.jpg}\\
WYDZIAŁ MATEMATYKI STOSOWANEJ\\[15mm]

{\huge praca licencjacka}\\[12mm]

{\Large
    \@title\\[2mm]
    \@engtitle
}\\[40mm]
\end{center}

\noindent
\begin{tabular}{ll}
Autor: & \@author\\
Nr albumu: & \@nralbumu\\
Kierunek studiów: & \@kierunek\\
Opiekun pracy: & \@opiekun\\
\end{tabular}\\[10mm]

\vfill

\begin{center}
{Kraków, \@date}
\end{center}

\end{titlepage}

%--- Czyszczenie zmiennych po wygenerowaniu strony ---%
\global\let\maketitle\relax
\global\let\title\relax
\global\let\author\relax
\global\let\date\relax
\global\let\engtitle\relax
\global\let\kierunek\relax
\global\let\opiekun\relax
\global\let\nralbumu\relax
}

\endinput
